# ============================================================
# METAROLE AI — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file: cp .env.example .env
# Fill in your actual values. NEVER commit .env to git.
# ============================================================

# --- AI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# --- DATABASE ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/metarole

# --- VECTOR DATABASE (choose one) ---
# Option A: Pinecone (cloud)
PINECONE_API_KEY=
PINECONE_ENV=us-east-1
PINECONE_INDEX=metarole-skills

# Option B: FAISS (local, default)
FAISS_INDEX_PATH=./data/faiss_index

# --- AUTH ---
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
JWT_SECRET=change_this_to_a_random_secret_string
JWT_EXPIRE_HOURS=24

# --- CACHE ---
REDIS_URL=redis://localhost:6379

# --- FRONTEND ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- DEPLOYMENT (set in production) ---
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
# DATABASE_URL=postgresql://user:pass@prod-db-host/metarole
